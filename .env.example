# Database
DATABASE_URL="postgresql://user:password@host:5432/journeyperfect?sslmode=require"

# Auth
NEXTAUTH_URL="https://www.journeyperfect.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Google Places API (console.cloud.google.com)
# NEXT_PUBLIC_ is used client-side for autocomplete; GOOGLE_PLACES_KEY is used server-side for search
NEXT_PUBLIC_GOOGLE_PLACES_KEY="your-google-places-api-key"
GOOGLE_PLACES_KEY="your-google-places-api-key"
